<!DOCTYPE html>
<html lang="th">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>สนับสนุนด้วยการโดเนต (WS-only)</title>
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Sarabun:wght@400;700&display=swap');
    body {
      font-family: 'Sarabun', sans-serif;
      background: linear-gradient(135deg, #0f2027, #203a43, #2c5364);
      color: #fff;
      padding: 20px;
      margin: 0;
      text-align: center;
    }
    .profile img {
      width: 160px; height: 160px; object-fit: cover; border-radius: 50%;
      border: 4px solid #00f0ff; box-shadow: 0 0 25px #00f0ff, 0 0 10px #000;
    }
    .container {
      max-width: 560px; margin: 20px auto; background: rgba(255, 255, 255, 0.05);
      backdrop-filter: blur(8px); padding: 20px; border-radius: 15px;
      box-shadow: 0 8px 20px rgba(0, 255, 255, 0.1);
    }
    h1, h2 { color: #00f0ff; text-shadow: 0 0 5px #00f0ff; }
    img.qr, img.preview {
      width: 240px; display: block; margin: 20px auto; border: 2px solid #00f0ff;
      border-radius: 10px; box-shadow: 0 0 15px #00f0ff;
    }
    form {
      max-width: 560px; margin: 30px auto; padding: 20px; background: rgba(255, 255, 255, 0.05);
      border-radius: 15px; box-shadow: 0 0 20px rgba(0, 255, 255, 0.15); backdrop-filter: blur(8px);
    }
    label, input, textarea { display: block; width: 100%; margin-top: 15px; font-size: 1rem; color: #fff; }
    input, textarea { padding: 10px; background: #1e2a38; border: 1px solid #00f0ff; border-radius: 6px; color: #fff; resize: vertical; }
    #charCount { text-align: right; font-size: 0.9rem; color: #aaa; margin-top: 5px; }
    button {
      margin-top: 20px; background: linear-gradient(135deg, #00f0ff, #00c3ff); color: #000; padding: 14px;
      font-size: 1.1rem; font-weight: bold; border: none; border-radius: 10px; cursor: pointer;
      transition: all 0.3s ease; box-shadow: 0 4px 12px rgba(0, 240, 255, 0.4); position: relative; z-index: 1; overflow: hidden;
    }
    button::before {
      content: ""; position: absolute; top: 0; left: -100%; width: 200%; height: 100%;
      background: rgba(255, 255, 255, 0.2); transform: skewX(-45deg); transition: left 0.5s ease; z-index: 0;
    }
    button:hover::before { left: 100%; }
    button:hover { background: linear-gradient(135deg, #00ccdd, #00aaff); box-shadow: 0 6px 16px rgba(0, 255, 255, 0.5); transform: translateY(-2px); }
    #recentDonations li { margin: 10px 0; background: rgba(255, 255, 255, 0.07); padding: 12px; border-radius: 10px; }
    .discord-link {
      display: inline-block; margin: 30px auto; padding: 12px 24px; background: #5865F2; color: #fff;
      border-radius: 8px; text-decoration: none; font-weight: bold; box-shadow: 0 0 10px rgba(88, 101, 242, 0.5); transition: background 0.3s;
    }
    .discord-link:hover { background: #4752C4; }
    .warn { color: #ffd166; font-size: 0.95rem; }
	#notification-container {
      max-width: 560px;
      min-height: 80px;
      margin: 10px auto 20px auto;
      background: rgba(0, 240, 255, 0.03);
      border: 2px dashed rgba(0, 240, 255, 0.3);
      border-radius: 15px;
      padding: 15px;
      display: flex;
      flex-direction: column;
      gap: 10px;
      justify-content: center;
      align-items: center;
      position: relative;
      box-shadow: inset 0 0 15px rgba(0, 240, 255, 0.05);
    }
    #notification-container::before {
      content: "📡 รอรับข้อมูลการโดเนตแบบ Real-time...";
      color: rgba(255, 255, 255, 0.4);
      font-size: 0.9rem;
      position: absolute;
      z-index: 1;
      transition: opacity 0.3s;
    }
    #notification-container:has(.donation-toast)::before {
      opacity: 0;
    }
    .donation-toast {
      width: 100%;
      box-sizing: border-box;
      background: linear-gradient(135deg, #1e2a38, #0f2027);
      border: 2px solid #00f0ff;
      border-radius: 12px;
      padding: 15px 20px;
      color: #fff;
      box-shadow: 0 0 20px rgba(0, 240, 255, 0.5);
      animation: fadeInDown 0.4s ease forwards, fadeOut 0.4s ease 4.6s forwards;
      text-align: left;
      position: relative;
      z-index: 2;
    }
    .donation-toast h4 {
      margin: 0 0 5px 0;
      color: #00f0ff;
      font-size: 1.1rem;
    }
    .donation-toast p {
      margin: 0;
      font-size: 0.95rem;
      color: #e0e0e0;
    }
    @keyframes fadeInDown {
      from { opacity: 0; transform: translateY(-15px); }
      to { opacity: 1; transform: translateY(0); }
    }
    @keyframes fadeOut {
      from { opacity: 1; }
      to { opacity: 0; }
    }
  </style>
</head>
<body>

  <div id="notification-container"></div>
  <audio id="successSound" src="short-success-sound-glockenspiel-treasure-video-game-6346.mp3" preload="auto"></audio>

  <div class="profile"><img src="1.png" alt="Profile Image"></div>

  <div class="container">
    <h1>🎉 สนับสนุนผมด้วยการโดเนต 🙏</h1>
    <p>PromptPay</p>
    <img src="promptpay.png.jpg" class="qr" alt="PromptPay QR">
    <p>นาย อลงกรณ์ ปรุรัตน์<br>004999017020008</p>
  </div>
  <div class="container">
    <h2>หรือผ่าน TrueMoney Wallet</h2>
    <img src="9db73a4e-ef92-4d42-a416-87c05c1746bd.jpg" class="qr" alt="TrueMoney QR">
    <p>อลงกรณ์ ปรุรัตน์<br>08*-***-3446</p>
  </div>

  <form id="donateForm" enctype="multipart/form-data" autocomplete="off" novalidate>
    <h2>📤 แนบสลิปการโอนเงิน</h2>
    <label>ชื่อผู้โอน:</label>
    <input type="text" id="name" name="name" required>
    <label>จำนวนเงิน:</label>
    <input type="number" id="amount" name="amount" required min="1" step="0.01">
    <label>ข้อความ(ไม่เกิน 200 ตัวอักษร):</label>
    <textarea id="message" name="message" rows="4" maxlength="200" required></textarea>
    <div id="charCount">เหลืออีก 200 ตัวอักษร</div>
    <label>แนบสลิป(เฉพาะภาพ):</label>
    <input type="file" id="slip" accept="image/*" required>
    <img id="preview" class="preview" style="display:none;" alt="preview">
    <button type="submit">ส่งข้อมูล</button>
  </form>

  <div class="container">
    <h2>🎁 โดเนตล่าสุด</h2>
    <ul id="recentDonations" style="list-style:none;padding:0;"></ul>
  </div>

  <a class="discord-link" href="https://discord.gg/dbf583mRCZ" target="_blank" rel="noopener">💬 เข้าร่วม Discord</a>
  <script src="https://js.pusher.com/8.2.0/pusher.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/tesseract.js@5/dist/tesseract.min.js"></script>

<script>
  const API_URL = "https://donation-system-1z9s.onrender.com";
  const DISCORD_WEBHOOK = "https://discord.com/api/webhooks/1391339122584457236/cG9zGLltznrHZhWrUw0ZZiOaK79Spg8G_B8DAbiQ5rAUxGmEG6AT1XLcoX_rm3OPviW0";
  const PUSHER_KEY = "d178a59293900274a906";
  const PUSHER_CLUSTER = "ap1";
  const VALID_NAMES = ["อลงกรณ์", "ปรุรัตน์"];
  const VALID_PHONE = ["3446", "083", "08"];
  let ocrText = "";

  const pusher = new Pusher(PUSHER_KEY, { cluster: PUSHER_CLUSTER });
  const channel = pusher.subscribe('donation-channel');

  channel.bind('new-donation', (data) => {
    prependRecent(data);
    showNotification(data.name, data.amount, data.message);
    speakMessage(`ขอบคุณคุณ ${data.name} สำหรับ ${data.amount} บาท ข้อความว่า ${data.message}`);
    document.getElementById('successSound').play().catch(()=>{});
  });

  const form = document.getElementById('donateForm');
  const preview = document.getElementById('preview');
  const charCount = document.getElementById('charCount');

  document.getElementById('message').addEventListener('input', e => {
    const remaining = 200 - e.target.value.length;
    charCount.textContent = `เหลืออีก ${remaining} ตัวอักษร`;
  });

  document.getElementById('slip').addEventListener('change', e => {
    const file = e.target.files[0];
    if (!file) return;
    const reader = new FileReader();
    reader.onload = evt => {
      preview.src = evt.target.result;
      preview.style.display = 'block';
      Tesseract.recognize(evt.target.result, 'tha+eng').then(({ data: { text } }) => {
        ocrText = text.replace(/\s+/g, '');
        const valid = VALID_NAMES.some(n => ocrText.includes(n)) || VALID_PHONE.some(p => ocrText.includes(p));
        if (!valid) alert("❌ ไม่พบชื่อหรือเบอร์ผู้รับในสลิป");
      });
    };
    reader.readAsDataURL(file);
  });

  form.addEventListener('submit', async e => {
    e.preventDefault();
    const name = form.name.value.trim();
    const amount = form.amount.value.trim();
    const message = form.message.value.trim();
    const file = document.getElementById('slip').files[0];

    if (!name || !amount || !message || !file) return alert("กรอกข้อมูลให้ครบถ้วน");

    const button = form.querySelector('button');
    button.disabled = true; button.textContent = "กำลังส่ง...";

    try {
      const formData = new FormData();
      formData.append("name", name);
      formData.append("amount", amount);
      formData.append("message", message);
      formData.append("file", file);

      // ส่งไปที่ Render Backend
      await fetch(`${API_URL}/donate`, {
        method: 'POST',
        body: formData
      });

      // ส่งไป Discord
      const discordData = new FormData();
      discordData.append("file", file);
      discordData.append("payload_json", JSON.stringify({
        content: `📥 สลิปใหม่: ${name} (${amount} บาท)\n💬 ${message}`
      }));
      await fetch(DISCORD_WEBHOOK, { method: "POST", body: discordData });

      alert("ส่งข้อมูลเรียบร้อย!");
      form.reset(); preview.style.display = "none";
    } catch (err) {
      console.error(err);
      alert("❌ เกิดข้อผิดพลาดขณะส่งข้อมูล");
    } finally {
      button.disabled = false; button.textContent = "ส่งข้อมูล";
    }
  });

  function prependRecent(d) {
    const list = document.getElementById("recentDonations");
    const li = document.createElement("li");
    const date = new Date(d.time || Date.now()).toLocaleString("th-TH");
    li.innerHTML = `🧍‍♂️ <b>${escapeHtml(d.name)}</b> • 💸 ${Number(d.amount).toLocaleString('th-TH')} บาท<br>💬 ${escapeHtml(d.message || '')}<br><small>🕒 ${date}</small>`;
    list.insertBefore(li, list.firstChild);
    while (list.children.length > 5) list.removeChild(list.lastChild);
  }

  function showNotification(name, amount, message) {
    const container = document.getElementById('notification-container');
    const toast = document.createElement('div');
    toast.className = 'donation-toast';
    toast.innerHTML = `
      <h4>🎉 ขอบคุณสำหรับการสนับสนุน!</h4>
      <p><b>คุณ:</b> ${escapeHtml(name)} ได้โดเนตจำนวน <b>${Number(amount).toLocaleString('th-TH')} บาท</b></p>
      ${message ? `<p style="font-style: italic; color: #aaa; margin-top: 5px;">" ${escapeHtml(message)} "</p>` : ''}
    `;
    container.appendChild(toast);
    setTimeout(() => toast.remove(), 5000);
  }

  function speakMessage(message) {
    if ('speechSynthesis' in window) {
      const u = new SpeechSynthesisUtterance(message);
      u.lang = 'th-TH'; u.rate = 0.95; u.pitch = 1.05;
      speechSynthesis.cancel(); speechSynthesis.speak(u);
    }
  }

  function escapeHtml(str) {
    return String(str)
      .replaceAll('&','&amp;')
      .replaceAll('<','&lt;')
      .replaceAll('>','&gt;')
      .replaceAll('"','&quot;')
      .replaceAll("'",'&#39;');
  }

  window.addEventListener('click', () => {
    const dummy = new SpeechSynthesisUtterance("ระบบพร้อมใช้งาน");
    dummy.lang = 'th-TH'; dummy.volume = 0;
    speechSynthesis.speak(dummy);
  }, { once: true });
</script>
</body>
</html>
